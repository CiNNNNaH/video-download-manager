{
  "app_name": "Video Download Manager",
  "version": "VDM_v1.2.0",
  "theme": "system",
  "default_browser": "chrome",
  "fallback_browsers": true,
  "default_download_dir": "",
  "default_view_mode": "simple",
  "remux_enabled": true,
  "target_container": "auto",
  "filename_template": "%(title)s.%(ext)s",
  "default_media_mode": "video+audio",
  "remember_last_browser": true,
  "remember_last_download_dir": true,
  "startup_dependency_check": true,
  "auto_prompt_missing_dependencies": true,
  "detailed_logging": true,
  "yt_dlp_path": "",
  "ffmpeg_path": "",
  "deno_path": "",
  "prefer_portable_tools": true,
  "allow_system_path_updates": false,
  "check_online_updates_on_startup": true,
  "installer_prefer_winget": true
}
